---
// TODO(ralph): Build Who We Are section
// Eyebrow: "Who we are"
// Two subsections: Our Mission, Our Vision
---
<section id="who-we-are" class="bg-[color:var(--color-bg-elevated)] py-24">
  <div class="mx-auto max-w-7xl px-6">
    <p class="mb-2 text-sm uppercase tracking-[0.2em] text-[color:var(--color-accent)]">Who we are</p>
    <div class="grid gap-12 md:grid-cols-2">
      <div>
        <h3 class="mb-4 text-3xl font-semibold md:text-[44px] md:leading-[52.8px]">Our Mission</h3>
        <p class="text-[color:var(--color-fg-muted)]">(mission copy to be pulled from reference)</p>
      </div>
      <div>
        <h3 class="mb-4 text-3xl font-semibold md:text-[44px] md:leading-[52.8px]">Our Vision</h3>
        <p class="text-[color:var(--color-fg-muted)]">(vision copy to be pulled from reference)</p>
      </div>
    </div>
  </div>
</section>
