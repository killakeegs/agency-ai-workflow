---
// TODO(ralph): Build Industries section
// Eyebrow: "INDUSTRIES WE SERVE"
// 3 callouts: Behavioral Health & Addiction, Specialized Therapy Practices, Wellness & Integrative Health
const industries = [
  'Behavioral Health & Addiction',
  'Specialized Therapy Practices',
  'Wellness & Integrative Health',
];
---
<section id="industries" class="bg-[color:var(--color-bg-elevated)] py-24">
  <div class="mx-auto max-w-7xl px-6">
    <p class="mb-12 text-sm uppercase tracking-[0.2em] text-[color:var(--color-accent)]">Industries we serve</p>
    <div class="grid gap-6 md:grid-cols-3">
      {industries.map((i) => (
        <div class="rounded-2xl border border-[color:var(--color-border)] p-8">
          <h3 class="text-2xl font-semibold">{i}</h3>
        </div>
      ))}
    </div>
  </div>
</section>
