---
// TODO(ralph): Build Services section
// Eyebrow: "Our Services"
// Heading: "Results-Driven Digital Marketing Services"
// "Our Newest Offering" callout for AI-Powered Marketing
// Cards: Content & Social Media, SEO, PPC, Website Design & Development, CRM & EMR, AI-Powered (newest)
const services = [
  { title: 'Content & Social Media Marketing', newest: false },
  { title: 'SEO Marketing', newest: false },
  { title: 'PPC Marketing', newest: false },
  { title: 'Website Design & Development', newest: false },
  { title: 'CRM & EMR Management', newest: false },
  { title: 'AI-Powered Marketing', newest: true },
];
---
<section id="services" class="bg-[color:var(--color-bg)] py-24">
  <div class="mx-auto max-w-7xl px-6">
    <p class="mb-2 text-sm uppercase tracking-[0.2em] text-[color:var(--color-accent)]">Our Services</p>
    <h2 class="mb-12 text-4xl font-semibold md:text-[60px] md:leading-[60px]">
      Results-Driven Digital Marketing Services
    </h2>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {services.map((s) => (
        <div class="rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-bg-elevated)] p-8">
          {s.newest && (
            <span class="mb-3 inline-block rounded-full bg-[color:var(--color-accent)] px-3 py-1 text-xs font-semibold text-black">
              Our Newest Offering
            </span>
          )}
          <h3 class="text-2xl font-semibold">{s.title}</h3>
        </div>
      ))}
    </div>
  </div>
</section>
