---
// Stats overview — inside overview-section-2 on reference.
// Live site uses Webflow animated "counter" columns; values below are
// best-estimate placeholders flagged for team confirmation (see CHECKLIST.md).
const stats = [
  { value: '150+', label: 'Successful Campaigns Delivered' },
  { value: '98%', label: 'Client Satisfaction Rate' },
  { value: '12+', label: 'Years Of Marketing Experience' },
  { value: '5x', label: 'Average ROI Achieved' },
];
---
<section id="stats" class="relative bg-[color:var(--color-bg)] py-20 md:py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-2 gap-y-12 md:grid-cols-4 md:gap-x-8">
      {stats.map(({ value, label }, i) => (
        <div
          class={`flex flex-col items-center text-center md:items-start md:text-left ${i > 0 ? 'md:border-l md:border-[color:var(--color-border)] md:pl-8' : ''}`}
        >
          <div class="text-5xl font-bold leading-none tracking-tight text-[color:var(--color-fg)] md:text-6xl lg:text-[72px]">
            {value}
          </div>
          <div class="mt-4 max-w-[18ch] text-sm font-medium uppercase tracking-wider text-[color:var(--color-fg-muted)] md:text-xs lg:text-sm">
            {label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
