# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Notion ─────────────────────────────────────────────────────────────────────
# Get your integration token at https://www.notion.so/my-integrations
NOTION_API_KEY=secret_
# The ID of the top-level page where client pages will be created
# Found in the page URL: notion.so/<workspace>/<PAGE_ID>
NOTION_WORKSPACE_ROOT_PAGE_ID=

# ── ClickUp ────────────────────────────────────────────────────────────────────
# Get your API key at https://app.clickup.com/settings/apps
CLICKUP_API_KEY=pk_
# Your workspace (Team) ID — found in ClickUp URL: app.clickup.com/<WORKSPACE_ID>/
CLICKUP_WORKSPACE_ID=
# Optional: default Space ID for new client folders
CLICKUP_DEFAULT_SPACE_ID=

# ── Replicate (image generation) ───────────────────────────────────────────────
# Get your API token at https://replicate.com/account/api-tokens
REPLICATE_API_KEY=r8_

# ── Pexels (stock photography for client image libraries) ──────────────────────
# Free API — create an account and request a key at https://www.pexels.com/api/
# Used by: make stock-images — pulls curated images per client → local + Notion
PEXELS_API_KEY=

# ── Unsplash (stock photos for lifestyle/people image categories) ───────────────
# Create a free app at https://unsplash.com/developers — use the "Access Key"
# When set: hero_lifestyle and detail_closeup fetch real stock photos instead of AI-generated
# When not set: falls back to Replicate for all categories
UNSPLASH_ACCESS_KEY=

# ── Google Drive (migration script only) ───────────────────────────────────────
# Path to service account JSON file for Google Drive access
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./credentials/gdrive-service-account.json

# ── Notifications ──────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-
SLACK_CHANNEL_INTERNAL=#agency-pipeline
GMAIL_SENDER_ADDRESS=

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
