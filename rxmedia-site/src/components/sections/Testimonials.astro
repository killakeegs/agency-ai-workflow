---
// Testimonials — 3 real client quotes extracted from reference HTML.
const quotes = [
  {
    quote:
      'RxMedia has gone to far lengths to ensure that everything is set up and operating the way we need it to. Communication and customer service is truly top notch.',
    name: 'Anthony Ciarrocchi',
    role: 'COO, LA Valley Recovery',
    logo: '/images/ribbon/la-valley.avif',
  },
  {
    quote:
      'Great company to work with. Keegan and his crew are smart and easy to get along with. They are knowledgeable with all the new marketing and SEO trends.',
    name: 'Justin McCoy',
    role: 'CEO, Freedom Recovery',
    logo: '/images/ribbon/freedom.avif',
  },
  {
    quote:
      "I've been working with RxMedia since I started with my new company this year and am continuously impressed with everything RxMedia does for us. Their employees are not only great at what they do, but are super personable and always willing to help out! We can see the incredible quality of their work directly through the leads we get and we're very pleased!",
    name: 'Emily Minerowicz',
    role: 'Marketing Coordinator, Buena Vista',
    logo: '/images/ribbon/buena-vista.avif',
  },
];
---
<section id="testimonials" class="bg-[color:var(--color-bg)] py-24 md:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-12 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-[color:var(--color-accent)]">
          Testimonials
        </p>
        <h2 class="max-w-3xl text-4xl font-semibold leading-tight md:text-5xl lg:text-[60px] lg:leading-[60px]">
          Hear What Our Clients Say <span class="text-[color:var(--color-accent)]">About Us</span>
        </h2>
      </div>
      <a
        href="/testimonials"
        class="inline-flex items-center gap-2 self-start text-sm font-semibold uppercase tracking-[0.2em] text-[color:var(--color-accent)] transition hover:gap-3 md:self-end"
      >
        View all
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {quotes.map((t) => (
        <figure class="flex h-full flex-col rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-bg-elevated)] p-8">
          <svg class="mb-6 h-8 w-8 text-[color:var(--color-accent)]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M7 7h4v4H7v2c0 1.1.9 2 2 2v2c-2.2 0-4-1.8-4-4V7zm9 0h4v4h-4v2c0 1.1.9 2 2 2v2c-2.2 0-4-1.8-4-4V7z" />
          </svg>
          <blockquote class="flex-1 text-sm leading-relaxed text-[color:var(--color-fg-subtle)] md:text-base">
            “{t.quote}”
          </blockquote>
          <figcaption class="mt-8 flex items-center gap-4 border-t border-[color:var(--color-border)] pt-6">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-[color:var(--color-bg-muted)] p-2">
              <img
                src={t.logo}
                alt=""
                aria-hidden="true"
                loading="lazy"
                width="40"
                height="40"
                class="max-h-full max-w-full object-contain"
              />
            </div>
            <div>
              <div class="font-semibold text-[color:var(--color-fg)]">{t.name}</div>
              <div class="text-xs text-[color:var(--color-fg-muted)]">{t.role}</div>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
